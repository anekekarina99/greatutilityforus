# Production domain — set juga di Vercel → Settings → Environment Variables
NEXT_PUBLIC_SITE_URL=https://bmifree.com

# ── Iklan Adsterra ──
NEXT_PUBLIC_ADS_ENABLED=true
NEXT_PUBLIC_ADS_PROVIDER=adsterra

# Banner 728×90 — key dari kode Adsterra (iframe 728x90)
NEXT_PUBLIC_ADSTERRA_BANNER_KEY=

# Native Banner — script URL + container ID dari kode Adsterra native
NEXT_PUBLIC_ADSTERRA_NATIVE_SCRIPT_URL=
NEXT_PUBLIC_ADSTERRA_NATIVE_CONTAINER_ID=

# AdSense (nanti) — ganti NEXT_PUBLIC_ADS_PROVIDER=adsense
# NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX
# NEXT_PUBLIC_ADSENSE_BANNER_SLOT=XXXXXXXXXX
# NEXT_PUBLIC_ADSENSE_NATIVE_SLOT=XXXXXXXXXX
