# Production domain — set juga di Vercel → Settings → Environment Variables
NEXT_PUBLIC_SITE_URL=https://bmifree.com

# ── PART 3: Iklan (setelah dapat key dari Adsterra dashboard) ──
# Aktifkan iklan: true | false
NEXT_PUBLIC_ADS_ENABLED=false

# Provider: adsterra | adsense
NEXT_PUBLIC_ADS_PROVIDER=adsterra

# Adsterra — buat 2 ad unit di dashboard (Banner 728x90 + Rectangle 300x250)
# Copy nilai "key" dari kode iklan Adsterra
NEXT_PUBLIC_ADSTERRA_BANNER_KEY=
NEXT_PUBLIC_ADSTERRA_RECTANGLE_KEY=

# AdSense (nanti, setelah approved) — ganti provider ke adsense
# NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX
# NEXT_PUBLIC_ADSENSE_BANNER_SLOT=XXXXXXXXXX
# NEXT_PUBLIC_ADSENSE_RECTANGLE_SLOT=XXXXXXXXXX
